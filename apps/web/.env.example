# API Configuration
# Note: API URL should include /api path for REST endpoints
VITE_API_URL=http://localhost:8080/api

# Socket.IO Configuration
# Note: Socket URL should be the base URL WITHOUT /api
# If not set, it will be automatically extracted from VITE_API_URL
VITE_SOCKET_URL=http://localhost:8080

# Environment
VITE_NODE_ENV=development

# Voice AI (Vapi)
# Get these from https://dashboard.vapi.ai
VITE_VAPI_PUBLIC_KEY=your_vapi_public_token_here
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
